# {{ project_name }} -- environment template. Copy to .env (never commit .env).
#
# Without provider keys set, the AI runtime falls back to a deterministic local
# provider so the project still installs, tests, and runs in CI.

APP_ENV=local
APP_LOG_LEVEL=INFO

# --- PostgreSQL ------------------------------------------------------------
APP_POSTGRES_URL=postgresql+asyncpg://app:app@localhost:5432/app

# --- Redis (rate limit backend / Celery broker) ----------------------------
APP_REDIS_URL=redis://localhost:6379/0

# --- LLM routing (OpenRouter) ----------------------------------------------
OPENROUTER_API_KEY=
OPENROUTER_MODEL=anthropic/claude-3-haiku

# --- Multimodal extraction (optional; mocked in local) ---------------------
GEMINI_API_KEY=
OPENAI_API_KEY=

# --- WhatsApp / Meta (set at deploy; mocked in local) ----------------------
META_APP_SECRET=
META_VERIFY_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
KAPSO_GATEWAY_URL=http://localhost:4000

# --- Security --------------------------------------------------------------
# Generate with: python -c "from sample.security import generate_key; print(generate_key())"
APP_ENCRYPTION_KEY=

# --- Rate limiting (per-IP). memory:// for single-process; redis://... for prod
APP_RATE_LIMIT_STORAGE=memory://
APP_RATE_LIMIT_DEFAULT=120/minute
APP_RATE_LIMIT_WEBHOOK=600/minute
APP_RATE_LIMIT_ONBOARD=30/minute

# --- Dashboard / CORS ------------------------------------------------------
APP_DASHBOARD_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
